#version 330 core

layout (location = 0) in vec3 aPos;
layout (location = 1) in vec2 aTexCoords;

out vec4 FragPos;
out vec2 TexCoords;

uniform mat4 model;
uniform mat4 view;
uniform mat4 projection;

void main() {
  FragPos   = vec4(aPos, 1.0);
  TexCoords = aTexCoords;

  gl_Position = projection*view*model*FragPos;
//gl_Position = (projection*view*model*FragPos).xyww;
//gl_Position = view*model*FragPos;
}
